{
  "name": "@goatcitadel/gateway",
  "version": "0.6.0-beta.2",
  "type": "module",
  "main": "./dist/apps/gateway/src/main.js",
  "dependencies": {
    "adm-zip": "0.5.16",
    "@inquirer/prompts": "^7.8.4",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@goatcitadel/contracts": "workspace:*",
    "@goatcitadel/gateway-core": "workspace:*",
    "@goatcitadel/mesh-core": "workspace:*",
    "@goatcitadel/memory-core": "workspace:*",
    "@goatcitadel/policy-engine": "workspace:*",
    "@goatcitadel/orchestration": "workspace:*",
    "@goatcitadel/skills": "workspace:*",
    "@goatcitadel/storage": "workspace:*",
    "chalk": "^5.6.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ora": "^9.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.7"
  },
  "scripts": {
    "dev": "tsx src/dev-supervisor.ts",
    "dev:watch": "tsx src/dev-supervisor.ts",
    "dev:supervisor": "tsx src/dev-supervisor.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage.enabled --coverage.provider=v8 --coverage.reporter=json --coverage.reporter=text-summary --coverage.reportsDirectory=coverage",
    "coverage:smoke": "c8 --report-dir=coverage-smoke --reporter=json tsx src/coverage-smoke.ts",
    "coverage:exercise": "c8 --report-dir=coverage-exercise --reporter=json tsx src/coverage-exercise.ts",
    "smoke": "tsx src/smoke.ts",
    "onboarding:tui": "tsx src/onboarding-tui.ts",
    "tui": "tsx src/tui/main.ts",
    "doctor": "tsx src/doctor/cli.ts",
    "tools": "tsx src/tui/tools-cli.ts",
    "voice:runtime": "tsx src/voice-runtime-cli.ts",
    "admin": "tsx src/admin-cli.ts",
    "config:sync": "tsx src/config-sync.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  }
}


