{
  "name": "goatcitadel",
  "private": true,
  "version": "0.6.0-beta.2",
  "packageManager": "pnpm@10.29.3",
  "bin": {
    "goatcitadel": "./bin/goatcitadel.mjs",
    "goat": "./bin/goatcitadel.mjs",
    "gc": "./bin/goatcitadel.mjs"
  },
  "scripts": {
    "dev": "pnpm dev:all",
    "dev:all": "pnpm --parallel --filter @goatcitadel/gateway --filter @goatcitadel/mission-control dev",
    "up": "pnpm dev:all",
    "dev:gateway": "pnpm --filter @goatcitadel/gateway dev",
    "dev:gateway:watch": "pnpm --filter @goatcitadel/gateway dev:watch",
    "dev:ui": "pnpm --filter @goatcitadel/mission-control dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "smoke": "pnpm --filter @goatcitadel/gateway smoke",
    "onboarding:tui": "pnpm --filter @goatcitadel/gateway onboarding:tui",
    "tui": "pnpm --filter @goatcitadel/gateway tui",
    "doctor": "pnpm --filter @goatcitadel/gateway run doctor",
    "tools": "pnpm --filter @goatcitadel/gateway tools",
    "admin": "pnpm --filter @goatcitadel/gateway admin",
    "brand:derive": "node scripts/brand/derive-assets.mjs",
    "config:sync": "pnpm --filter @goatcitadel/gateway config:sync",
    "prompt:gates": "pnpm tsx scripts/run-prompt-pack-gates.ts",
    "prompt:gates:targeted": "pnpm tsx scripts/run-prompt-pack-gates.ts --target-only",
    "screenshots:capture": "pnpm --filter @goatcitadel/policy-engine exec node scripts/capture-mission-control-screenshots.mjs",
    "inventory:inline-sql": "node scripts/inventory-inline-sql.mjs",
    "coverage:collect": "node scripts/coverage-collect.mjs",
    "coverage:gate": "node scripts/coverage-gate.mjs",
    "docs:check": "node scripts/validate-governance-docs.mjs && node scripts/check-button-types.mjs && node scripts/check-no-inline-sql.mjs",
    "check:buttons": "node scripts/check-button-types.mjs",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@types/node": "^24.3.0",
    "c8": "^10.1.3",
    "sharp": "^0.34.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}


