{
  "environment": "local",
  "defaultToolProfile": "chat-agent",
  "dataDir": "./data",
  "transcriptsDir": "./data/transcripts",
  "auditDir": "./data/audit",
  "workspaceDir": "./workspace",
  "worktreesDir": "./.worktrees",
  "auth": {
    "mode": "token",
    "allowLoopbackBypass": false,
    "token": {
      "queryParam": "access_token"
    },
    "basic": {}
  },
  "approvalExplainer": {
    "enabled": true,
    "mode": "async",
    "minRiskLevel": "caution",
    "timeoutMs": 15000,
    "maxPayloadChars": 4000
  },
  "memory": {
    "enabled": true,
    "qmd": {
      "enabled": true,
      "applyToChat": true,
      "applyToOrchestration": true,
      "minPromptChars": 48,
      "maxContextTokens": 1400,
      "headroomTokens": 600,
      "maxTranscriptEvents": 80,
      "maxMemoryFiles": 36,
      "maxBytesPerFile": 64000,
      "allowedExtensions": [
        ".md",
        ".txt",
        ".json",
        ".yaml",
        ".yml",
        ".log",
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ],
      "cacheTtlSeconds": 300,
      "distiller": {
        "timeoutMs": 12000,
        "fallbackCheapModel": "gpt-4.1-nano"
      }
    }
  },
  "mesh": {
    "enabled": true,
    "mode": "lan",
    "nodeId": "bld-main",
    "discovery": {
      "mdns": true,
      "staticPeers": []
    },
    "security": {
      "joinTokenEnv": "GOATCITADEL_MESH_JOIN_TOKEN",
      "requireMtls": true,
      "tailnet": {
        "enabled": false
      }
    },
    "leases": {
      "ttlSeconds": 30
    },
    "replication": {
      "batchSize": 200
    }
  },
  "npu": {
    "enabled": false,
    "autoStart": false,
    "sidecar": {
      "baseUrl": "http://127.0.0.1:11440",
      "command": "python",
      "args": [
        "apps/npu-sidecar/server.py"
      ],
      "healthPath": "/health",
      "modelsPath": "/v1/models",
      "startTimeoutMs": 20000,
      "requestTimeoutMs": 12000,
      "restartBudget": {
        "windowMs": 60000,
        "maxRestarts": 5,
        "backoffMs": 2000
      }
    }
  },
  "sqlite": {
    "cacheSizeKb": 32768,
    "tempStoreMemory": true,
    "walAutoCheckpointPages": 4000
  },
  "durable": {
    "enabled": false,
    "diagnosticsEnabled": false,
    "maxAttemptsDefault": 3
  },
  "features": {
    "durableKernelV1Enabled": false,
    "replayOverridesV1Enabled": false,
    "memoryLifecycleAdminV1Enabled": false,
    "connectorDiagnosticsV1Enabled": false,
    "computerUseGuardrailsV1Enabled": true,
    "bankrBuiltinEnabled": false,
    "cronReviewQueueV1Enabled": false,
    "replayRegressionV1Enabled": false
  },
  "budgets": {
    "dailyUsdWarning": 10,
    "dailyUsdHardCap": 50,
    "sessionTokenHardCap": 120000
  }
}