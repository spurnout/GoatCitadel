{
  "profileId": "private-beta",
  "description": "Tailnet private-beta hardened defaults (auth + cron posture).",
  "assistant": {
    "auth": {
      "mode": "token",
      "allowLoopbackBypass": false,
      "token": {
        "queryParam": "access_token"
      }
    },
    "features": {
      "computerUseGuardrailsV1Enabled": true,
      "bankrBuiltinEnabled": false
    }
  },
  "cronJobs": {
    "jobs": [
      {
        "jobId": "self_improvement_weekly_replay",
        "name": "Self-Improvement Weekly Replay",
        "schedule": "0 2 * * 0 America/Los_Angeles",
        "enabled": true
      },
      {
        "jobId": "private_beta_backup_daily",
        "name": "Private Beta Daily Backup",
        "schedule": "30 2 * * * America/Los_Angeles",
        "enabled": true
      }
    ]
  }
}
