NODE_ENV=development
GATEWAY_PORT=8787
GATEWAY_HOST=127.0.0.1
MISSION_CONTROL_ORIGIN=http://localhost:5173
DATA_DIR=./data
WORKSPACE_DIR=./workspace
OPENAI_API_KEY=
GLM_API_KEY=
MOONSHOT_API_KEY=

# Optional auth overrides (configure via Mission Control Forge tab for persistence)
# GOATCITADEL_AUTH_MODE=token
# GOATCITADEL_AUTH_TOKEN=replace-with-strong-token
# GOATCITADEL_AUTH_BASIC_USERNAME=operator
# GOATCITADEL_AUTH_BASIC_PASSWORD=replace-with-strong-password
# GOATCITADEL_AUTH_ALLOW_LOOPBACK_BYPASS=false
# GOATCITADEL_WARN_UNAUTH_NON_LOOPBACK=true # keep startup warnings on when testing bind/auth posture
# GOATCITADEL_ALLOW_UNAUTH_NETWORK=1 # insecure override, only for isolated local debugging
# GOATCITADEL_ALLOW_REMOTE_APPROVAL_CREATE=1 # insecure override, enables remote synthetic approvals
# GOATCITADEL_FEATURE_BANKR_BUILTIN_ENABLED=false # optional legacy toggle; built-in Bankr stays off by default

# Optional mesh overrides (LAN-first, disabled by default)
# GOATCITADEL_MESH_ENABLED=true
# GOATCITADEL_MESH_MODE=lan
# GOATCITADEL_MESH_NODE_ID=my-node-01
# GOATCITADEL_MESH_JOIN_TOKEN=replace-with-join-token

# Advanced local voice runtime overrides (managed whisper.cpp is the default path)
# GOATCITADEL_WHISPER_CPP_BIN=
# GOATCITADEL_WHISPER_CPP_MODEL_PATH=
# GOATCITADEL_WHISPER_CPP_ARGS=
# GOATCITADEL_FFMPEG_BIN=

# Private beta (Tailnet) hardened profile
# GOATCITADEL_AUTH_MODE=token
# GOATCITADEL_AUTH_TOKEN=replace-with-long-random-token
# GOATCITADEL_AUTH_ALLOW_LOOPBACK_BYPASS=false
# GOATCITADEL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://bld:5173,https://bld.ts.net
# GOATCITADEL_VITE_ALLOWED_HOSTS=localhost,127.0.0.1,bld,.ts.net
# VITE_GATEWAY_ALLOWED_HOSTS=localhost,127.0.0.1,bld,.ts.net
