{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@goatcitadel/contracts": ["packages/contracts/src/index.ts"],
      "@goatcitadel/storage": ["packages/storage/src/index.ts"],
      "@goatcitadel/gateway-core": ["packages/gateway-core/src/index.ts"],
      "@goatcitadel/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@goatcitadel/skills": ["packages/skills/src/index.ts"],
      "@goatcitadel/orchestration": ["packages/orchestration/src/index.ts"],
      "@goatcitadel/mesh-core": ["packages/mesh-core/src/index.ts"]
    },
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  }
}
