NODE_ENV=development
GATEWAY_PORT=8787
GATEWAY_HOST=0.0.0.0
MISSION_CONTROL_ORIGIN=http://bld:5173

# Private beta auth (required for non-loopback bind)
GOATCITADEL_AUTH_MODE=token
GOATCITADEL_AUTH_TOKEN=replace-with-long-random-token
GOATCITADEL_AUTH_ALLOW_LOOPBACK_BYPASS=false
GOATCITADEL_WARN_UNAUTH_NON_LOOPBACK=true
# GOATCITADEL_ALLOW_UNAUTH_NETWORK=1 # break-glass only; never enable in shared/public environments
# GOATCITADEL_ALLOW_REMOTE_APPROVAL_CREATE=1 # optional break-glass override (default is loopback-only)
# GOATCITADEL_FEATURE_BANKR_BUILTIN_ENABLED=false # leave disabled unless explicitly migrating legacy Bankr usage

# Tailnet/LAN origin and host allowlists
GOATCITADEL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://bld:5173,https://bld.ts.net
GOATCITADEL_VITE_ALLOWED_HOSTS=localhost,127.0.0.1,bld,.ts.net
VITE_GATEWAY_ALLOWED_HOSTS=localhost,127.0.0.1,bld,.ts.net

# Model providers
OPENAI_API_KEY=
GLM_API_KEY=
MOONSHOT_API_KEY=
